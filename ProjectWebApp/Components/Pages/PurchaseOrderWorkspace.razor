@page "/purchaseorderworkspace/{VendorID:int}"
@using MudBlazor


<PageTitle>Purchase Order Workspace</PageTitle>

<MudText Typo="Typo.h3">Purchase Order Workspace</MudText>


<MudText Typo="Typo.h5">Vendor Information</MudText>

<MudText>Vendor: @workspace.VendorName</MudText>
<MudText>Phone: @workspace.Phone</MudText>
<MudText>Address: @workspace.Address</MudText>
<MudText>@workspace.City, @workspace.ProvinceID @workspace.PostalCode</MudText>

<MudText Typo="Typo.h6">Order Totals</MudText>

<MudText>Subtotal: @workspace.SubTotal.ToString("0.00")</MudText>
<MudText>GST: @workspace.TaxAmount.ToString("0.00")</MudText>
<MudText>Total: @workspace.Total.ToString("0.00")</MudText>
<MudText Typo="Typo.h6">Actions</MudText>

<MudButton Variant="Variant.Filled"
           Color="Color.Primary"
           Disabled="@(!canSave)">
    Save / Update
</MudButton>

<MudButton Variant="Variant.Filled"
           Color="Color.Secondary"
           Disabled="@(!canPlace)">
    Place
</MudButton>

<MudButton Variant="Variant.Filled"
           Color="Color.Error">
    Delete
</MudButton>

<MudButton Variant="Variant.Filled"
           Color="Color.Info">
    Clear
</MudButton>

@if (!string.IsNullOrWhiteSpace(validationMessage))
{
    <MudText Typo="Typo.body1">@validationMessage</MudText>
}

<MudText Typo="Typo.h6">
    Purchase Order ID: @workspace.PurchaseOrderID
</MudText>
<MudText Typo="Typo.h5">Suggested / Current Order Items</MudText>

<MudTable Items="workspace.CurrentOrderItems" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>Part ID</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>QOH</MudTh>
        <MudTh>QOO</MudTh>
        <MudTh>ROL</MudTh>
        <MudTh>QTO</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PartID</MudTd>
        <MudTd>@context.Description</MudTd>
        <MudTd>@context.QOH</MudTd>
        <MudTd>@context.QOO</MudTd>
        <MudTd>@context.ROL</MudTd>
        <MudTd>
            <MudNumericField T="int"
                             Value="context.QTO"
                             ValueChanged="@(x => UpdateQuantity(context, x))"
                             Min="0"
                             Immediate="true" />
</MudTd>
<MudTd>
            <MudNumericField T="decimal"
                             Value="context.PurchasePrice"
                             ValueChanged="@(x => UpdatePrice(context, x))"
                             Min="0"
                             Immediate="true" />
</MudTd>
        <MudTd>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       OnClick="@(() => RemovePart(context.PartID))">
                Remove
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>
<MudText Typo="Typo.h5">Available Parts</MudText>

<MudTable Items="workspace.AvailableParts" Hover="true" Dense="true" Striped="true">
    <HeaderContent>
        <MudTh>Part ID</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>QOH</MudTh>
        <MudTh>QOO</MudTh>
        <MudTh>ROL</MudTh>
        <MudTh>Buffer</MudTh>
        <MudTh>Price</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.PartID</MudTd>
        <MudTd>@context.Description</MudTd>
        <MudTd>@context.QOH</MudTd>
        <MudTd>@context.QOO</MudTd>
        <MudTd>@context.ROL</MudTd>
        <MudTd>@context.Buffer</MudTd>
        <MudTd>@context.PurchasePrice</MudTd>
        <MudTd>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@(() => AddPart(context.PartID))">
                Add
            </MudButton>
        </MudTd>
    </RowTemplate>
</MudTable>